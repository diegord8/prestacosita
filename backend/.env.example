# Puerto local. Render asignará su propio puerto.
PORT=3001

# En tu computadora se utiliza development.
# En Render debes colocar production.
NODE_ENV=development

# Conexión pooled de Neon.
# Se utiliza normalmente para ejecutar el backend.
DATABASE_URL=postgresql://usuario:contraseña@host-pooler.neon.tech/neondb?sslmode=require

# Conexión directa de Neon.
# Se utiliza para ejecutar migraciones.
DATABASE_URL_DIRECT=postgresql://usuario:contraseña@host.neon.tech/neondb?sslmode=require

# Opcional: base de datos separada para pruebas.
DATABASE_URL_TEST=postgresql://usuario:contraseña@host.neon.tech/neondb_test?sslmode=require

# Clave para firmar los tokens.
JWT_SECRET=coloca_una_clave_larga_y_segura

# Uno o varios frontends separados por comas.
FRONTEND_URLS=http://localhost:5173
